{
  "name": "vinit-sutar-portfolio",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact.js" },
    { "source": "/api/analytics", "destination": "/api/analytics.js" },
    { "source": "/api/projects", "destination": "/api/projects.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" }
  ]
}